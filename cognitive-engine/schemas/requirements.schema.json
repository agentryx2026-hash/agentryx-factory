{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentryx.dev/schemas/requirements.schema.json",
  "title": "Genovi — structured requirement extraction",
  "description": "Output shape of Genovi's intake analysis. Produced by task='intake' LLM run; consumed by A0_Source_Analysis.md renderer and downstream agents (Picard, Sisko, Troi).",
  "type": "object",
  "required": [
    "project_summary",
    "domain",
    "primary_actors",
    "functional_requirements",
    "estimated_complexity"
  ],
  "properties": {
    "project_summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "One-sentence description of what is being built."
    },
    "domain": {
      "type": "string",
      "enum": [
        "e-commerce",
        "finance",
        "healthcare",
        "education",
        "devtools",
        "saas-b2b",
        "saas-b2c",
        "gaming",
        "media",
        "gov-public",
        "logistics",
        "iot-industrial",
        "ai-ml-ops",
        "other"
      ],
      "description": "Broad industry classification."
    },
    "primary_actors": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Roles/personas that interact with the system (e.g. 'registered user', 'admin', 'external api consumer')."
    },
    "functional_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "priority", "description"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^FR-[0-9]{3,4}$",
            "description": "Assigned ID, e.g. FR-001."
          },
          "priority": {
            "type": "string",
            "enum": ["MUST", "SHOULD", "COULD", "WILL_NOT"],
            "description": "MoSCoW priority."
          },
          "description": {
            "type": "string",
            "minLength": 10,
            "description": "What the system MUST do."
          },
          "actor": {
            "type": "string",
            "description": "Which actor this applies to (optional; subset of primary_actors)."
          }
        }
      }
    },
    "non_functional_requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "description"],
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "performance",
              "security",
              "reliability",
              "usability",
              "accessibility",
              "maintainability",
              "portability",
              "compliance",
              "scalability",
              "other"
            ]
          },
          "description": { "type": "string", "minLength": 5 },
          "target_metric": {
            "type": "string",
            "description": "Optional measurable target, e.g. 'p95 response time < 200ms'"
          }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "External constraints (tech stack mandated by customer, deadline, budget, etc.)."
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Things the scope doc implies but doesn't state."
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Concrete, testable criteria for considering the build complete."
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ambiguities or gaps to clarify with the user before proceeding. Surface these to Phase 9 verify portal."
    },
    "scope_exclusions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Things explicitly out of scope."
    },
    "estimated_complexity": {
      "type": "string",
      "enum": ["small", "medium", "large", "xl"],
      "description": "S=1 dev-week, M=2-4, L=1-3 months, XL=quarter+."
    },
    "recommended_tech_stack_hints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Suggestions for Picard's A2_Solution_Architecture to consider (not prescriptive)."
    }
  },
  "additionalProperties": false
}
